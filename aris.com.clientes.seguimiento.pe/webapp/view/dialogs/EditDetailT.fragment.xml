<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:l="sap.ui.layout"
    xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:u="sap.ui.unified"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:footer="sap.ushell.ui.footerbar">

   <Dialog
    title="{i18n>textbtnModificar}"
    contentHeight="auto"
    contentWidth="40%"
    afterOpen="_afterOpenEditTextil"
    draggable="true"
    resizable="true">

        <VBox justifyContent="Center" alignItems="Center" class="sapUiMediumMargin">
            <Title text="MODIFICAR POSICIÓN" class="sapUiLargeMarginBottom"/>

            <core:Icon
                src="sap-icon://cart"
                size="4rem"
                color="#E69A17"
                class="sapUiSmallMarginBottom"/>

            <HBox justifyContent="Start" class="sapUiSmallMarginBottom">
                <Label text="Código:"/>
                <Text
                    id="textCodigoMaterial"
                    text="{oModelProyect>/oMaterialesSelectedMatnr}"
                    class="sapUiSmallMarginBegin"/>
            </HBox>

            <HBox justifyContent="Start" class="sapUiSmallMarginBottom">
                <Label text="Descripción:"/>
                <Text
                    text="{oModelProyect>/oMaterialesSelectedDesc}"
                    class="sapUiSmallMarginBegin"/>
            </HBox>

            <l:Grid defaultSpan="L4 M4 S12" hSpacing="2" width="100%">
                <l:content>
                    <Text text=""/>
                    <Title text="CTD"/>
                    <Title text="UMV"/>

                    <Label
                        text="Stock"
                        visible="{= !${oModelUser>/bIsCliente} }"/>
                    <Input
                        id="inputStock"
                        width="100%"
                        enabled="false"
                        visible="{= !${oModelUser>/bIsCliente} }"
                        value="{oModelProyect>/oSelecTableDetalle/StockDispoView}"/>

                    <Input
                        id="inputStockUmv"
                        width="100%"
                        enabled="false"
                        visible="{= !${oModelUser>/bIsCliente} }"
                        value="{
                            parts: [
                                { path: 'oModelProyect>/oSelecTableDetalle/UMV' },
                                { path: 'oModelProyect>/inputForm/grupoMaterial' },
                                { path: 'oModelProyect>/oSelecTableDetalle/Brand' }
                            ],
                            formatter: '.formatter.formatUMVTextil'
                        }"/>

                    <Label text="Cantidad"/>

                    <Input
                        id="inputCantidadModificada"
                        width="100%"
                        value="{oModelProyect>/oSelecTableDetalle/cantidad}"
                        type="Number"
                        textAlign="End"
                        liveChange="_onLiveChangeCantidadModificadaTextil"/>

                    <Input
                        width="100%"
                        enabled="false"
                        value="{
                            parts: [
                                { path: 'oModelProyect>/oSelecTableDetalle/UMV' },
                                { path: 'oModelProyect>/inputForm/grupoMaterial' },
                                { path: 'oModelProyect>/oSelecTableDetalle/Brand' }
                            ],
                            formatter: '.formatter.formatUMVTextil'
                        }"/>
                </l:content>
            </l:Grid>
        </VBox>

        <beginButton>
            <Button
                text="{i18n>textbtnGuardar}"
                type="Accept"
                icon="sap-icon://save"
                press="_onAcceptEditCantidad"/>
        </beginButton>

        <endButton>
            <Button
                text="{i18n>cancelText}"
                type="Reject"
                icon="sap-icon://decline"
                press="_onClose"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>