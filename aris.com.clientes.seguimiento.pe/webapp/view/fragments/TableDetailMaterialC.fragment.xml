<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:f="sap.ui.layout.form">

    <ScrollContainer
        width="100%"
        height="100%"
        horizontal="true"
        vertical="true">

        <Table
            id="tbProductosCerMod"
            items="{oModelProyect>/oMaterialUI}"
            growingThreshold="20"
            mode="MultiSelect"
            selectionChange="_onPressSelectionChange">

            <headerToolbar>
                <Toolbar>
                    <ToolbarSpacer />

                    <Button
                        id="btnAgregarDetailCerMod"
                        text="{i18n>textbtnAgregar}"
                        type="Emphasized"
                        icon="sap-icon://add"
                        press="_onPressAddProduct"
                        visible="{= !${oModelUser>/bIsCliente} }" />

                    <Button
                        id="btnAgregarDetailClienteCerMod"
                        text="{i18n>textbtnAgregar}"
                        type="Emphasized"
                        icon="sap-icon://add"
                        press="_onPressAddProductClient"
                        visible="{= ${oModelUser>/bIsCliente} }" />
                </Toolbar>
            </headerToolbar>

            <columns>
                <Column
                    id="colPosicionCerMod"
                    width="4.5rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="{i18n>txtTabledPosition}"
                            width="auto"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colMaterialCerMod"
                    width="4.5rem"
                    hAlign="Left"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="{i18n>txtTabledMaterial}"
                            width="14rem"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colDescripcionCerMod"
                    width="15rem"
                    hAlign="Left"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="Descripción"
                            width="14rem"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colCalidadCerMod"
                    width="4.5rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false"
                    visible="{= !${oModelUser>/bIsCliente}}">
                    <header>
                        <Text
                            text="Calidad"
                            width="4rem"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin"
                            visible="{= !${oModelUser>/bIsCliente}}" />
                    </header>
                </Column>

                <Column
                    id="colCalibreCerMod"
                    width="4.5rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false"
                    visible="{= !${oModelUser>/bIsCliente}}">
                    <header>
                        <Text
                            text="Calbr."
                            width="4rem"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin"
                            visible="{= !${oModelUser>/bIsCliente}}" />
                    </header>
                </Column>

                <Column
                    id="colTonoCerMod"
                    width="4rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false"
                    visible="{= !${oModelUser>/bIsCliente}}">
                    <header>
                        <Text
                            text="Tono"
                            width="4rem"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin"
                            visible="{= !${oModelUser>/bIsCliente}}" />
                    </header>
                </Column>

                <Column
                    id="colCantidadCerMod"
                    width="6rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="{i18n>txtTableAmount}"
                            width="4rem"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colUmvCerMod"
                    width="4rem"
                    hAlign="Center"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="{i18n>txtTabledUMV}"
                            width="5rem"
                            maxLines="2"
                            wrapping="true"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colPalletCerMod"
                    width="4.5rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="Pallet"
                            width="4rem"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colCajaCerMod"
                    width="4rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="Caja"
                            width="4rem"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colPesoCerMod"
                    width="6rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="Peso"
                            width="5rem"
                            maxLines="2"
                            wrapping="true"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colPrListaCerMod"
                    width="7rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="Pr.List"
                            width="5rem"
                            maxLines="2"
                            wrapping="true"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colDescuentoCerMod"
                    width="6rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="Dsto."
                            width="5rem"
                            maxLines="2"
                            wrapping="true"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colPrUnitCerMod"
                    width="4rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="Pr.Unit"
                            width="5rem"
                            maxLines="2"
                            wrapping="true"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colTotalCerMod"
                    width="7rem"
                    hAlign="End"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="{i18n>txtTabledTotal}"
                            width="auto"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colEditarMaterialCerMod"
                    width="4rem"
                    hAlign="Center"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="{i18n>txtTabledEdit}"
                            width="auto"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin" />
                    </header>
                </Column>

                <Column
                    id="colEliminarMaterialCerMod"
                    width="4.5rem"
                    hAlign="Center"
                    vAlign="Middle"
                    minScreenWidth="Tablet"
                    demandPopin="true"
                    popinDisplay="Inline"
                    mergeDuplicates="false">
                    <header>
                        <Text
                            text="{i18n>txtTabledEliminate}"
                            width="auto"
                            maxLines="2"
                            wrapping="false"
                            textAlign="Begin" />
                    </header>
                </Column>
            </columns>

            <items>
                <ColumnListItem type="Inactive">
                    <cells>
                        <Text text="{oModelProyect>Posicion}" />

                        <Text text="{oModelProyect>codigo}" />

                        <Text text="{oModelProyect>descripcion}" />

                        <Text
                            text="{oModelProyect>calidad}"
                            visible="{= !${oModelUser>/bIsCliente}}" />

                        <Text
                            text="{oModelProyect>calibre}"
                            visible="{= !${oModelUser>/bIsCliente}}" />

                        <Text
                            text="{oModelProyect>tono}"
                            visible="{= !${oModelUser>/bIsCliente}}" />

                        <Text
                            text="{
                                path: 'oModelProyect>cantidad',
                                formatter: '.formatter.formatMonto2Dec'
                            }"
                            textAlign="End"
                            width="100%" />

                        <Text text="{oModelProyect>UMV}" />

                        <Input
                            value="{
                                path: 'oModelProyect>cantidadPallets',
                                formatter: '.formatter.formatBultoEntero'
                            }"
                            editable="false"
                            width="100%"
                            textAlign="End" />

                        <Input
                            value="{
                                path: 'oModelProyect>cantidadCajas',
                                formatter: '.formatter.formatBultoEntero'
                            }"
                            editable="false"
                            width="100%"
                            textAlign="End" />

                        <Text
                            text="{
                                path: 'oModelProyect>peso',
                                formatter: '.formatter.formatMonto2Dec'
                            }"
                            textAlign="End" />

                        <Text
                            text="{
                                path: 'oModelProyect>prLista',
                                formatter: '.formatter.formatMonto2Dec'
                            }"
                            textAlign="End" />

                        <Text
                            text="{
                                path: 'oModelProyect>descuentos',
                                formatter: '.formatter.formatMonto2Dec'
                            }"
                            textAlign="End" />

                        <Text
                            text="{
                                path: 'oModelProyect>prUnit',
                                formatter: '.formatter.formatMonto2Dec'
                            }"
                            textAlign="End" />

                        <Text
                            text="{
                                path: 'oModelProyect>total',
                                formatter: '.formatter.formatMonto2Dec'
                            }"
                            textAlign="End" />

                        <Button
                            icon="sap-icon://edit"
                            type="Emphasized"
                            enabled="{= !${oModelProyect>BloqueaEdicionCalidadS} }"
                            tooltip="{= ${oModelProyect>BloqueaEdicionCalidadS} ? 'Las posiciones con calidad S no se pueden editar. Elimine la línea y agréguela nuevamente.' : 'Editar' }"
                            press="_onPressEditDetail" />

                        <Button
                            icon="sap-icon://delete"
                            type="Attention"
                            press="_onDeleteProduct" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>

        <HBox
            id="hbTotalesCerMod"
            width="100%"
            justifyContent="Center"
            class="sapUiSmallMarginTop"
            alignItems="Start">

            <VBox
                id="vbAnticipoNotaCreditoCerMod"
                width="30%"
                alignItems="End">

                <HBox
                    id="hbAnticipoCerMod"
                    alignItems="Center">
                    <Label
                        text="{i18n>txtFootertableAdvance}"
                        width="100px"
                        textAlign="End"
                        class="sapUiSmallMarginEnd" />

                    <Input
                        id="inpAnticipoCerMod"
                        value="{
                            path: 'oModelData>/Anticipo/OutstandingAmount',
                            formatter: '.formatter.formatMonto2Dec'
                        }"
                        width="100px"
                        textAlign="End"
                        editable="false" />
                </HBox>

                <HBox
                    id="hbNotaCreditoCerMod"
                    alignItems="Center">
                    <Label
                        text="{i18n>txtFootertableNC}"
                        width="100px"
                        textAlign="End"
                        class="sapUiSmallMarginEnd" />

                    <Input
                        id="inpNotaCreditoCerMod"
                        value="{
                            path: 'oModelData>/NotaCredito/NotaCredito',
                            formatter: '.formatter.formatMonto2Dec'
                        }"
                        width="100px"
                        textAlign="End"
                        editable="false" />
                </HBox>
            </VBox>

            <HBox
                id="hbSeparadorTotalesCerMod"
                width="20px" />

            <VBox
                id="vbTotalesImportesCerMod"
                width="30%">

                <HBox
                    id="hbSubTotalCerMod"
                    alignItems="Center">
                    <Label
                        text="{i18n>txtTabledSubTotal}"
                        width="120px"
                        textAlign="End"
                        class="sapUiSmallMarginEnd" />

                    <Input
                        id="inpSubTotalMatCerMod"
                        value="{
                            path: 'oModelProyect>/Totales/SubTotal',
                            formatter: '.formatter.formatMonto2Dec'
                        }"
                        width="100px"
                        textAlign="End"
                        editable="false" />
                </HBox>

                <HBox
                    id="hbFleteCerMod"
                    alignItems="Center">
                    <Label
                        text="{i18n>txtTableFlete}"
                        width="120px"
                        textAlign="End"
                        visible="{=${device>/system/phone}?false:true}"
                        class="sapUiSmallMarginEnd" />

                    <Input
                        id="inpTotalFleteCerMod"
                        value="{
                            path: 'oModelProyect>/Totales/Flete',
                            formatter: '.formatter.formatMonto2Dec'
                        }"
                        width="100px"
                        textAlign="End"
                        editable="false" />
                </HBox>

                <HBox
                    id="hbIgvCerMod"
                    alignItems="Center">
                    <Label
                        text="{i18n>txtTableIGV}"
                        width="120px"
                        textAlign="End"
                        class="sapUiSmallMarginEnd" />

                    <Input
                        id="inpTotalIgvMatCerMod"
                        width="100px"
                        value="{
                            path: 'oModelProyect>/Totales/IGV',
                            formatter: '.formatter.formatMonto2Dec'
                        }"
                        textAlign="End"
                        editable="false" />
                </HBox>

                <HBox
                    id="hbTotalCerMod"
                    alignItems="Center">
                    <Label
                        text="{i18n>titleFooterColProducto}"
                        width="120px"
                        textAlign="End"
                        class="sapUiSmallMarginEnd" />

                    <Input
                        id="inpTotalMatCerMod"
                        value="{
                            path: 'oModelProyect>/Totales/Total',
                            formatter: '.formatter.formatMonto2Dec'
                        }"
                        width="100px"
                        textAlign="End"
                        editable="false" />
                </HBox>
            </VBox>

            <VBox
                id="vbAddManualProductCerMod"
                visible="{oModelProyect>/showAddManualProduct}">
            </VBox>
        </HBox>
    </ScrollContainer>
</core:FragmentDefinition>