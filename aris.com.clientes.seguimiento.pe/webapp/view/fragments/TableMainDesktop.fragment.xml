<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form">
    <Table items="{oModelProyect>/oReporteFiltrado}"   mode="None" growingThreshold="20" autoPopinMode="false" growing="true" sticky="ColumnHeaders,HeaderToolbar" popinLayout="GridSmall">
        <columns>
            <Column width="100px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>titleColOrder}" width="auto" />
                </header>
            </Column>
           
            <Column width="50px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false" >
                <header>
                    <core:Icon  src ="sap-icon://pdf-attachment"/>
                </header>
            </Column>
            <Column width="180px" hAlign="Begin" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false" visible="{= ${oModelUser>/bRol}==='SUPERVISOR'? true:  ${oModelUser>/bRol}==='VENDEDOR'? true: false}">
                <header>
                    <HBox justifyContent="Center" width="100%">
                        <Text text="{i18n>titleColCompName}" width="auto" />
                     </HBox>
                </header>
            </Column>
            <Column width="80px" hAlign="Begin"  minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <HBox justifyContent="Center" width="100%">
                        <Text text="{i18n>titleColOrderType}" width="auto" />
                    </HBox>
                </header>
            </Column>
            <Column width="50px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>titleColCurrency}" width="auto" />
                </header>
            </Column>
            <Column width="100px" hAlign="End" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <HBox justifyContent="Center" width="100%">
                        <Text text="{i18n>titleColAmount}" width="auto" />
                    </HBox>
                </header>
            </Column>
            <Column width="100px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>titleColOrderDate}" width="auto" />
                </header>
            </Column>
            <Column width="100px" hAlign="Begin"  minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <HBox justifyContent="Center" width="100%">
                        <Text text="{i18n>titleColState}" width="auto" />
                    </HBox>
                </header>
            </Column>
            <Column
                width="50px"
                hAlign="Center"
                vAlign="Middle"
                minScreenWidth="Tablet"
                demandPopin="true"
                popinDisplay="Inline"
                mergeDuplicates="false"
                visible="{=
                    (
                        ${oModelUser>/bUniNeg} === 'TEXTILES' ||
                        ${oModelUser>/bUniNeg} === 'CERAMICOS'
                    )
                    &amp;&amp;
                    (
                        ${oModelUser>/bRol} === 'SUPERVISOR' ||
                        ${oModelUser>/bRol} === 'VENDEDOR'
                    )
                }">
                <header>
                    <Text text="{i18n>titleModify}" width="auto" />
                </header>
            </Column>
        </columns>
       <items>
            <ColumnListItem type="Inactive">
                <cells>
                    <Button type="Transparent" text="{path:'oModelProyect>SalesDocument'}" press="_onPressNavigateDetail"/>
                     <Link text="PDF" press="onPressDescargarPdfCotizacion"/>
                    <Text text="{path:'oModelProyect>CustomerFullName'}" />
                    <Text text="{path:'oModelProyect>DscSalesDocumentType'}"/>
                    <Text text="{path:'oModelProyect>TransactionCurrency'}"/>
                   <Text
                        text="{
                            path: 'oModelProyect>TotalNetAmount',
                            type: 'sap.ui.model.type.Float',
                            formatOptions: {
                                groupingEnabled: true,
                                groupingSeparator: ',',
                                decimalSeparator: '.',
                                minFractionDigits: 2,
                                maxFractionDigits: 2
                            }
                        }"/>
                    <Text text="{path:'oModelProyect>SalesDocumentDate'}"/>
                    <Text text="{path:'oModelProyect>EstadoGeneral'}"/>
                    <Button
                    icon="sap-icon://circle-task"
                        press="onModificar"
                        visible="{oModelProyect>MostrarBotonModificar}"/>
                </cells> 
            </ColumnListItem>
        </items>
     
    </Table>
</core:FragmentDefinition>