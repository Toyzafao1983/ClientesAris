<core:FragmentDefinition xmlns:threejs="sap.ui.vk.threejs" xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout"  
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:n="sap.n"
    xmlns:f="sap.f"
    xmlns:microchart="sap.suite.ui.microchart"
    xmlns:si="sap.suite.ui.commons.statusindicator"
    xmlns:co="sap.suite.ui.commons"
    xmlns:svm="sap.ui.comp.smartvariants"
    xmlns:form="sap.ui.layout.form">
     <VBox >
                       <form:SimpleForm
                                editable="false"
                                layout="ResponsiveGridLayout"
                                class="sapUiSmallMargin">
                                <Label text="Fecha Inicio" class="bigBoldLabel"/>
                                <Text text="{oModelExtra>/0/FechaInicio}"/>

                                <Label text="Fecha Fin" class="bigBoldLabel"/>
                                <Text text="{oModelExtra>/0/FechaFin}"/>
                        </form:SimpleForm>
                 <ScrollContainer width="100%" height="50%">
                        <Table id="vdTableCS1" items="{oModelProyect>/oDetalle}"  mode="None" growingThreshold="20" headerText="{i18n>titleSeOrderDetails}" popinLayout="GridSmall"  class="sapUiSmallMargin" >
                                <columns>
                                <Column width="5%" hAlign="End" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                                <HBox justifyContent="Center" width="100%">
                                                        <Text text="{i18n>titleSeNumPosition}" width="auto" />
                                                </HBox>
                                        </header>
                                        
                                </Column>
                                <Column width="5%" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                        <Text text="{i18n>titleSeMaterials}" width="auto" />
                                        </header>
                                    
                                </Column>
                                <Column width="30%" hAlign="Begin" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                                <HBox justifyContent="Center" width="100%">
                                                        <Text text="{i18n>titleSeDescription}" width="auto" />
                                                </HBox>
                                        </header>
                                </Column>
                                <Column width="10%" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                        <Text text="{i18n>titleSeUM}" width="auto" />
                                        </header>
                                     
                                </Column>
                                <Column width="10%" hAlign="End" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                         <HBox justifyContent="Center" width="100%">
                                        <Text text="{i18n>titleSeQuantityOrdered}" width="auto" />
                                         </HBox>
                                        </header>
                                      
                                </Column>
                                <Column width="10%" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                        <Text text="{i18n>titleSeStatusPosition}" width="auto" />
                                        </header>
                                </Column>
                                </columns>
                                <items>
                                        <ColumnListItem type="Inactive">
                                                <cells>
                                                 <Text text="{path:'oModelProyect>SalesDocumentItem'}" />
                                                <Text text="{path:'oModelProyect>Material'}"/>
                                                <Text text="{path:'oModelProyect>SalesDocumentItemText'}"/>
                                                <Text text="{path:'oModelProyect>OrderQuantityUnit'}"/>
                                                <Text text="{path:'oModelProyect>OrderQuantity'}"/>
                                                </cells>
                                        </ColumnListItem>
                                </items>
                                
                        </Table>
                         </ScrollContainer>
                         <ScrollContainer width="100%" height="50%">
                        <Table id="vdTableCS2" items="{oModelProyect>/oListCliente}" growing="true" mode="None" growingThreshold="10" headerText="{i18n>titlePASOtherCustomerOrders}" class="sapUiSmallMargin" >
                                <columns>
                                <Column width="7%" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                        <Text text="{i18n>titlePANOrder}" width="auto" />
                                        </header>
                                </Column>
                                <Column width="11%" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                        <Text text="{i18n>titlePACustomer}" width="auto" />
                                        </header>
                                </Column>
                                <Column width="28%" hAlign="Begin" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                                <HBox justifyContent="Center" width="100%">
                                                        <Text text="{i18n>titlePACompName}" width="auto" />
                                                </HBox>
                                        </header>
                                </Column>
                                <Column width="10%" hAlign="Begin" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                                <HBox justifyContent="Center" width="100%">
                                                        <Text text="{i18n>titlePAOrderType}" width="auto" />
                                                </HBox>
                                        </header>
                                </Column>
                                <Column width="8%" hAlign="End" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                                <HBox justifyContent="Center" width="100%">
                                                        <Text text="{i18n>titlePAAmount}" width="auto" />
                                                </HBox>
                                        </header>
                                </Column>
                                <Column width="10%" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                        <Text text="{i18n>titlePAOrderDate}" width="auto" />
                                        </header>
                                </Column>
                                <Column width="10%" hAlign="Begin" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                                        <header>
                                                <HBox justifyContent="Center" width="100%">
                                                        <Text text="{i18n>titlePAState}" width="auto" />
                                                </HBox>
                                        </header>
                                </Column>
                                </columns>
                                <items>
                                        <ColumnListItem type="Inactive">
                                                <cells>
                                                <Button type="Transparent" text="{path:'oModelProyect>SalesDocument'}" press="_onPressNavigateDetail2"/>
                                                <Text text="{path:'oModelProyect>RUC'}"/>
                                                <Text text="{path:'oModelProyect>CustomerFullName'}"/>
                                                <Text text="{path:'oModelProyect>DscSalesDocumentType'}"/>
                                                <Text
                                                text="{
                                                path: 'oModelProyect>TotalNetAmount',
                                                type: 'sap.ui.model.type.Float',
                                                formatOptions: {
                                                        groupingEnabled: true,
                                                        groupingSeparator: ',',
                                                        decimalSeparator: '.',
                                                        minFractionDigits: 2,
                                                        maxFractionDigits: 2
                                                }
                                                }"/>
                                                <Text text="{path:'oModelProyect>RequestedDeliveryDate'}"/>
                                                <Text text="{path:'oModelProyect>EstadoGeneral'}"/>
                                                </cells>
                                        </ColumnListItem>
                                </items>
                                
                        </Table>
                         </ScrollContainer>

           </VBox>
</core:FragmentDefinition>