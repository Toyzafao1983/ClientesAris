<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form">
    <ScrollContainer
        width="100%"
        height="100%"
        horizontal="{= ${device>/system/phone} }"
        vertical="true"
        focusable="true">
        <Table items="{oModelProyect>/oDetalle}"  mode="None" growingThreshold="5" >
            <headerToolbar>
                <Toolbar>
                    <ToolbarSpacer/>
                </Toolbar>
            </headerToolbar>
            <columns>
                <Column width="4rem" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleTbstateDetail}" width="auto" />
                    </header>
                </Column>
                <Column width="12rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleTbDocumentDetail}" width="auto" />
                    </header>
                </Column>
                <Column width="3.5rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleTbrenewalDetail}" width="auto" wrapping="true"/>
                    </header>
                </Column>
                <Column width="5rem" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titlEbankDetail}" width="auto" wrapping="true"/>
                    </header>
                </Column>
                <Column width="5rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleTuniqueNumberDetail}" width="auto" wrapping="true"/>
                    </header>
                </Column>
                <Column width="6rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleDocumentDateDetail}" width="auto" wrapping="true"/>
                    </header>
                </Column>
                <Column width="6rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleDueDateDetail}" width="auto" wrapping="true"/>
                    </header>
                </Column>
                <Column width="3.5rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleCurrencyDetail}" width="auto" wrapping="true"/>
                    </header>
                </Column>
                <Column width="7rem" hAlign="End" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleAmountDetail}" width="auto" wrapping="true"/>
                    </header>
                </Column>
                <Column width="11.5rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titlePaymentConditionDetail}" width="auto" wrapping="true"/>
                    </header>
                </Column>
            </columns>
           <items>
                <ColumnListItem type="Inactive">
                    <cells>
                        <ObjectStatus
                            state="{= ${oModelProyect>Vencido} === '@0A@' ? 'Error' : (${oModelProyect>Vencido} === '@08@' ? 'Success' : 'None') }"
                            icon="sap-icon://stop"
                            visible="{= ${oModelProyect>Vencido} === '@0A@' || ${oModelProyect>Vencido} === '@08@' }"
                        />

                        <HBox fitContainer="true">
                            <items>
                                <Link
                                    text="{path:'oModelProyect>Xblnr'}"
                                    press=".onAbrirTestEcomprobantes"
                                    visible="{ path: 'oModelProyect>Xblnr', formatter: '._isLinkFactura' }"
                                />
                                <Text
                                    text="{path:'oModelProyect>Xblnr'}"
                                    visible="{ path: 'oModelProyect>Xblnr', formatter: '._isTextFactura' }"
                                />
                            </items>
                        </HBox>

                        <Text text="{path:'oModelProyect>ItemText'}"/>
                        <Text text="{path:'oModelProyect>Banco'}"/>
                        <Text text="{path:'oModelProyect>RefKey1'}"/>
                        <Text text="{ path: 'oModelProyect>DocDate', formatter: '._formatDateDDMMYYYY' }"/>
                        <Text text="{ path: 'oModelProyect>Netduedate', formatter: '._formatDateDDMMYYYY' }"/>
                        <Text text="{path:'oModelProyect>Waers'}"/>
                        <Text
                            visible="{= Number(String(${oModelProyect>Monto} || '0').replace(',', '.')) !== 0 }"
                            text="{ path: 'oModelProyect>Monto', formatter: '.formatter.formatMonto2Dec' }"
                        />
                        <Text text="{path:'oModelProyect>Condicion'}"/>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </ScrollContainer>
</core:FragmentDefinition>