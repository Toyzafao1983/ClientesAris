<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">
    <ScrollContainer
        width="100%"
        height="100%"
        horizontal="{= ${device>/system/phone} }"
        vertical="true"
        focusable="true">

        <Table items="{oModelProyect>/oLoanedProducts}"  growingThreshold="20">
            <columns>
                <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet"
                    demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleTbLoanedProduct}" width="auto" />
                    </header>
                </Column>

                <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet"
                    demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleTbCant}" width="auto" />
                    </header>
                </Column>

                <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet"
                    demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleTbMoney}" width="auto" />
                    </header>
                </Column>

                <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet"
                    demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleTbImporte}" width="auto" />
                    </header>
                </Column>
            </columns>

            <items>
                <ColumnListItem type="Inactive">
                    <cells>
                        <Text text="Parihuelas Enviadas"/>
                        <Text text="{path:'oModelProyect>Amountborrowed',formatter: '.formatter.formatEntero'}"/>
                        <Text text="{oModelProyect>Currency}"/>
                        <Text text="{path:'oModelProyect>Amount',formatter: '.formatter.formatMonto2Dec'}"/>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </ScrollContainer>
</core:FragmentDefinition>