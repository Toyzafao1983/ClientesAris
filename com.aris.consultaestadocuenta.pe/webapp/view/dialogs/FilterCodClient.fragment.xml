<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<SelectDialog   
        contentWidth="10rem"
        contentHeight="20rem"
		id="FilterCodClientDialog"
		noDataText="Buscar Cliente"
		title="Codigo del Cliente"
		multiSelect="true"
		liveChange=".onSearch"
		confirm=".onDialogClose"
		cancel=".onDialogClose"
		items="{
			path: 'oModelProyect>/oCliente'
		}">
		<StandardListItem
			title="{oModelProyect>Customer}" 
			description="{path: 'oModelProyect>CustomerFullName', formatter: '.formatter.cleanCustomerFullName'}"
			icon="sap-icon://customer"
			iconDensityAware="false"
			iconInset="false"
			type="Active" />
	</SelectDialog>
</core:FragmentDefinition>