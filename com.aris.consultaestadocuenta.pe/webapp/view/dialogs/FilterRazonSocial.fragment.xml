<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<SelectDialog   
        contentWidth="10rem"
        contentHeight="20rem"
		id="FilterRazSocialDialog"
		noDataText="Buscar Razon Social"
		title="Razon Social"
		multiSelect="true"
		liveChange=".onSearch"
		confirm=".onDialogClose"
		cancel=".onDialogClose"
		items="{
			path: 'oModelProyect>/oCliente',
			sorter: { path: 'CustomerFullName' }
		}">
		<StandardListItem
			title="{oModelProyect>CustomerFullName}"
			description="{path: 'oModelProyect>', formatter: '.formatter.getFirstTaxNumber'}"
			icon="sap-icon://building"
			iconDensityAware="false"
			iconInset="false"
			type="Active" />
	</SelectDialog>
</core:FragmentDefinition>