<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:l="sap.ui.layout"
    xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:u="sap.ui.unified"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:footer="sap.ushell.ui.footerbar">

    <Dialog
        title="{i18n>textbtnModificar}"
        contentHeight="auto"
        contentWidth="40%">

        <VBox justifyContent="Center" alignItems="Center" class="sapUiMediumMargin">
            <Title text="MODIFICAR BOLSA" class="sapUiLargeMarginBottom"/>

            <core:Icon
                src="sap-icon://cart"
                size="4rem"
                color="#E69A17"
                class="sapUiSmallMarginBottom"/>

            <HBox justifyContent="Start" class="sapUiSmallMarginBottom">
                <Label text="Código:"/>
                <Text text="{oModelProyect>/oBolsaSelected/Material}" class="sapUiSmallMarginBegin"/>
            </HBox>

            <l:Grid defaultSpan="L4 M4 S12" hSpacing="2">
                <l:content>
                    <Text text=""/>
                    <Title text="CTD"/>
                    <Title text="UMV"/>

                    <Label text="Cantidad actual"/>
                    <Input
                        width="100%"
                        enabled="false"
                        value="{oModelProyect>/oBolsaSelected/cantidad}"/>
                    <Input
                        width="100%"
                        enabled="false"
                        value="{oModelProyect>/oBolsaSelected/UMV}"/>

                    <Label text="Nueva cantidad"/>
                    <Input
                        width="100%"
                        id="inputCantidadBolsa"
                        value="{oModelProyect>/oBolsaSelected/cantidadNueva}"/>
                    <Input
                        width="100%"
                        enabled="false"
                        value="{oModelProyect>/oBolsaSelected/UMV}"/>
                </l:content>
            </l:Grid>
        </VBox>

        <HBox justifyContent="End">
            <Button
                text="{i18n>textbtnGuardar}"
                type="Accept"
                icon="sap-icon://save"
                press="_onAcceptEditBolsa"/>

            <Button
                text="{i18n>cancelText}"
                type="Reject"
                icon="sap-icon://decline"
                class="sapUiSmallMarginBegin"
                press="_onCloseBolsa"/>
        </HBox>
    </Dialog>
</core:FragmentDefinition>