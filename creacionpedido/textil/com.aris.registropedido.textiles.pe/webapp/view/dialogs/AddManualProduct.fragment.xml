<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:l="sap.ui.layout"
    xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:f="sap.ui.layout.form"
    displayBlock="true"
>
    <Dialog
        title="{i18n>titleDialogAddProducto}"
        contentWidth="60rem"
        contentHeight="50rem"
        resizable="true"
        draggable="true"
        afterOpen="_afterOpenAddPedido"
    >
        <content>
            <f:SimpleForm
                id="SimpleFormDisplay480_Trial3"
                editable="false"
                layout="ResponsiveGridLayout"
                title="{i18n>txtsearchMaterialD}"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                columnsXL="3"
                columnsL="2"
                columnsM="2"
            >
                <f:content>
                    <core:Title text="" />
                    <Label text="{i18n>txtCodMaterialD}" />
                   <MultiInput
                        id="miMaterial"
                        showSuggestion="true"
                        showValueHelp="true"
                        valueHelpRequest=".onOpenMaterialDialog"
                        suggest=".onSuggestMaterial"
                        suggestionItemSelected=".onMaterialSuggestionSelected"
                        tokenUpdate=".onMaterialTokenUpdate"
                        placeholder="Escriba o seleccione un material"
                        width="100%"
                        suggestionItems="{
                            path: 'oModelData>/oFilterMaterial'
                        }">
                        <suggestionItems>
                            <core:Item
                                key="{oModelData>Material}"
                                text="{
                                    parts: [
                                        'oModelData>Material',
                                        'oModelData>Description'
                                    ],
                                    formatter: '.formatter.formatMaterialWithDesc'
                                }" />
                        </suggestionItems>
                    </MultiInput>
                    
                    <core:Title text="" />
                    <Label text="{i18n>txtGroupMaterialD}" />
                    <Input value="{oModelProyect>/inputForm/grupoMaterialText}" enabled="false" />
                    <Label text="{i18n>txtBrand}" />
                    <MultiComboBox
                        id="mcBrand"
                        width="100%"
                        placeholder="Escriba o seleccione"
                        items="{
                            path: 'oModelData>/ListBrand'
                        }"
                        selectedKeys="{oModelProyect>/oSelectDetail/aBrands}"
                        selectionFinish=".onBrandSelectionFinish">

                        <core:Item
                            key="{oModelData>Brand}"
                            text="{= ${oModelData>Brand} + ' - ' + ${oModelData>DscBrand} }" />
                    </MultiComboBox>
                    <core:Title text="" />
                    <Label text="{i18n>txtArtTextil}" />
                    <MultiInput
                        id="miArtTextil"
                        showSuggestion="true"
                        showValueHelp="true"
                        valueHelpRequest=".onOpenArtTextilDialog"
                        suggest=".onSuggestArtTextil"
                        suggestionItemSelected=".onArtTextilSuggestionSelected"
                        tokenUpdate=".onArtTextilTokenUpdate"
                        placeholder="Escriba o seleccione"
                        width="100%"
                        suggestionItems="{ path: 'oModelData>/ListArtTextilSug' }">

                        <suggestionItems>
                            <core:Item
                                key="{oModelData>key}"
                                text="{
                                    parts: [
                                        'oModelData>key',
                                        'oModelData>text'
                                    ],
                                    formatter: '.formatter.formatMaterialWithDesc'
                                }" />
                        </suggestionItems>
                    </MultiInput>
                    <!-- ORILLO -->
                    <Label text="{i18n>txtOrilloD}" />
                    <MultiInput
                        id="miOrillo"
                        width="300px"
                        showClearIcon="true"
                        showSuggestion="true"
                        showValueHelp="true"
                        valueHelpRequest=".onOpenOrilloDialog"
                        liveChange="onOrilloChange"
                        suggest="onOrilloChange"
                        tokenUpdate=".onOrilloTokenUpdate"
                        suggestionItemSelected=".onOrilloSuggestionItemSelected"
                        suggestionItems="{ path: 'oModelData>/oFiltroOrilloSuggest' }"
                        custom:custom="cbOrillo/cbOrilloPrefix2">
                        <suggestionItems>
                            <core:Item key="{oModelData>key}" text="{oModelData>Display}" />
                        </suggestionItems>
                    </MultiInput>
                </f:content>
            </f:SimpleForm>

            <f:SimpleForm
                id="SimpleFormDisplay480_Trial4"
                editable="false"
                layout="ResponsiveGridLayout"
                title=""
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                columnsXL="3"
                columnsL="2"
                columnsM="2"
            >
                <f:content>
                </f:content>
            </f:SimpleForm>

            <Table
                items="{oModelProyect>/oMaterialSelect}"
                id="tbMaterialesManual"
                growingThreshold="20"
                mode="MultiSelect"
            >
                <headerToolbar>
                    <Toolbar>
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>txtButtonClean}"
                            icon="sap-icon://decline"
                            press=".onLimpiarPress"
                            type="Reject"
                        />
                        <Button
                            text="{i18n>titleTableBuscar}"
                            icon="sap-icon://search"
                            press=".onBuscarPress"
                            type="Emphasized"
                        />
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column
                        width="auto"
                        hAlign="Left"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>titleAddColCant}"
                                width="auto"
                                maxLines="1"
                                wrapping="false"
                                textAlign="Begin"
                                textDirection="Inherit"
                                visible="true"
                            />
                        </header>
                    </Column>
                    <Column
                        width="auto"
                        hAlign="Left"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>txtTableMaterial}"
                                width="auto"
                                maxLines="1"
                                wrapping="false"
                                textAlign="Begin"
                                textDirection="Inherit"
                                visible="true"
                            />
                        </header>
                    </Column>
                    <Column
                        width="auto"
                        hAlign="Left"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>txtTableLine}"
                                width="auto"
                                maxLines="1"
                                wrapping="false"
                                textAlign="Begin"
                                textDirection="Inherit"
                                visible="true"
                            />
                        </header>
                    </Column>
                    <Column
                        width="auto"
                        hAlign="Left"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>txtTableDescriptions}"
                                width="auto"
                                maxLines="1"
                                wrapping="false"
                                textAlign="Begin"
                                textDirection="Inherit"
                                visible="true"
                            />
                        </header>
                    </Column>
                   <!-- <Column
                        width="10%"
                        hAlign="Left"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>txtTableUMV}"
                                width="auto"
                                maxLines="1"
                                wrapping="true"
                                textAlign="Begin"
                                textDirection="Inherit"
                                visible="{= !${oModelUser>/hideAdvancedFields}}"
                            />
                        </header>
                    </Column>-->
                    <Column
                        width="10%"
                        hAlign="Left"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                        visible="{= !${oModelUser>/bIsCliente}}"
                    >
                        <header>
                            <Text
                                text="{i18n>txtStock}"
                                width="auto"
                                maxLines="1"
                                wrapping="false"
                                textAlign="Begin"
                                textDirection="Inherit"
                               visible="{= !${oModelUser>/bIsCliente}}"
                                
                            /> 
                        </header>
                    </Column>

                       <Column
                            width="10%"
                            hAlign="Center"
                            vAlign="Middle"
                            minScreenWidth="Tablet"
                            demandPopin="true"
                            popinDisplay="Inline"
                            mergeDuplicates="false"
                            visible="{= !${oModelUser>/bIsCliente}}"
                        >
                            <header>
                                <Text
                                    text="Pieza"
                                    width="auto"
                                    maxLines="1"
                                    wrapping="false"
                                    textAlign="Begin"
                                    textDirection="Inherit"
                                    visible="{= !${oModelUser>/bIsCliente}}"
                                />
                            </header>
                        </Column>
                </columns>
                <items>
                    <ColumnListItem type="Inactive">
                        <cells>
                            <Input
                                    value="{oModelProyect>cantidad}"
                                    width="auto"
                                    enabled="{oModelProyect>CantidadEditable}"
                                    liveChange="_onLiveChangeCantidad"
                                />
                            <ObjectStatus
                                text="{oModelProyect>Matnr}"
                                state="{ path: 'oModelProyect>StockDispo', formatter: '.formatter.stockState' }"/>
                            <ObjectStatus
                                text="{oModelProyect>Linea}"
                                state="{ path: 'oModelProyect>StockDispo', formatter: '.formatter.stockState' }"/>
                            <ObjectStatus
                                text="{oModelProyect>Bezei}"
                                state="{ path: 'oModelProyect>StockDispo', formatter: '.formatter.stockState' }"/>

                          <!--<ObjectStatus
                                text="{
                                    parts: [
                                        { path: 'oModelProyect>Um' },
                                        { path: 'oModelProyect>/inputForm/grupoMaterial' },
                                        { path: 'oModelProyect>Brand' }
                                    ],
                                    formatter: '.formatter.formatUMVTextil'
                                }"
                                state="{ path: 'oModelProyect>StockDispo', formatter: '.formatter.stockState' }"/>--> 
                        
                            <ObjectStatus
                                text="{oModelProyect>StockDispo}"
                                state="{ path: 'oModelProyect>StockDispo', formatter: '.formatter.stockState' }" visible="{= !${oModelUser>/bIsCliente}}"/>
                            
                            <Link  text="{oModelProyect>pieza}" press=".onPressPieza" visible="{= !${oModelUser>/bIsCliente}}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <buttons>
            <Button
                id="btnAcceptAddManualProduct"
                text="{i18n>confirmProductText}"
                press="_onAcceptProductManual"
                custom:custom="default"
                type="Critical"
                icon="sap-icon://accept"
            />
            <Button
                id="btnCloseAddManualProduct"
                text="{i18n>cancelText}"
                press="_onPressClose"
                custom:custom="default"
                type="Reject"
                icon="sap-icon://cancel"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
