<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <SelectDialog
        id="ValueHelpArtTextilRegistro"
        title="Artículo Textil"
        multiSelect="true"
        search=".onArtTextilDialogSearch"
