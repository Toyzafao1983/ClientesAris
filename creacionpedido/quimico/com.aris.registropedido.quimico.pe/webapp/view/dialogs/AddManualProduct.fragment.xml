<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:l="sap.ui.layout"
    xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:f="sap.ui.layout.form"
    displayBlock="true"
>
    <Dialog
        title="{i18n>titleDialogAddProducto}"
        contentWidth="58rem"
        contentHeight="50rem"
        resizable="true"
        draggable="true"
        afterOpen="_afterOpenAddPedido"

    >
        <content>
        <VBox fitContainer="true">
            <f:SimpleForm
                id="SimpleFormDisplay480_Trial3"
                editable="false"
                layout="ResponsiveGridLayout"
                title="{i18n>txtsearchMaterialD}"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                columnsXL="3"
                columnsL="2"
                columnsM="2"
            >
                <f:content>
                    <core:Title text="" />
                        <Label text="{i18n>txtCodMaterialD}" />
                        <MultiInput
                            id="miMaterial"
                            showValueHelp="true"
                            valueHelpRequest=".onVHMaterial"
                            showSuggestion="true"
                            suggest=".onSuggestMaterial"
                            suggestionItemSelected=".onMaterialSuggestionSelected"
                            tokenUpdate=".onMaterialTokenUpdate"
                            placeholder="Escriba o seleccione un material"
                            width="100%"
                            suggestionItems="{ path: 'oModelData>/oFilterMaterial' }">
                            <suggestionItems>
                                <core:Item
                                key="{oModelData>Material}"
                                text="{
                                    parts: ['oModelData>Material','oModelData>Description'],
                                    formatter: '.formatter.formatMaterialWithDesc'
                                }" />
                            </suggestionItems>
                            </MultiInput>
                        <Label text="{i18n>txtDescriptionsD}" />
                        <MultiInput
                            id="miDescription"
                            showValueHelp="true"
                            valueHelpRequest=".onVHDescription"
                            showSuggestion="true"
                            suggest=".onSuggestDescription"
                            suggestionItemSelected=".onDescriptionSuggestionSelected"
                            tokenUpdate=".onDescriptionTokenUpdate"
                            placeholder="Escriba o seleccione"
                            width="100%"
                            suggestionItems="{ path: 'oModelData>/ListDescriptionSug' }">
                            <suggestionItems>
                                <core:Item key="{oModelData>Material}" text="{oModelData>Description}" />
                            </suggestionItems>
                            </MultiInput>


                        <core:Title text="" />
                        <Label text="{i18n>txtGroupMaterialD}" />
                        <ComboBox
                            id="cbGrupoMaterial"
                            selectedKey="{oModelProyect>/oSelectDetail/grupoMaterial}"
                            items="{ path: 'oModelData>/oMaterialGroup' }"
                            showClearIcon="true"
                            placeholder="Seleccione un grupo de material">
                            <core:Item
                                key="{oModelData>MaterailGroup}"
                                text="{= ${oModelData>MaterailGroup} + ' - ' + ${oModelData>Description} }" />
                        </ComboBox>
                        <Label text="{i18n>txtBrand}" />
                        <MultiComboBox
                            id="mcBrand"
                            width="100%"
                            placeholder="Escriba o seleccione"
                            selectionChange=".onBrandSelectionChange"
                            items="{
                                path: 'oModelData>/ListBrand'
                            }">

                            <core:Item
                                key="{oModelData>Brand}"
                                text="{= ${oModelData>Brand} + ' - ' + ${oModelData>DscBrand} }" />
                        </MultiComboBox>
                    <core:Title text="" />
                </f:content>
            </f:SimpleForm>

            <Table
            id="tbMaterialesManual"
            items="{oModelProyect>/oMaterialSelect}"
            growing="true"
            growingThreshold="20"
            growingScrollToLoad="false"
            growingTriggerText="Cargar más"
            width="100%"
            updateFinished=".onUpdateFinishedQuimicos"
            >
                <headerToolbar>
                    <Toolbar>
                        <ToolbarSpacer />
                        <Button
                            text="{i18n>txtButtonClean}"
                            icon="sap-icon://decline"
                            press=".onLimpiarPress"
                            type="Reject"
                        />
                        <Button
                            text="{i18n>titleTableBuscar}"
                            icon="sap-icon://search"
                            press=".onBuscarPress"
                            type="Emphasized"
                        />
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column
                        width="6rem"
                        hAlign="End"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>titleAddColCant}"
                                width="auto"
                                maxLines="1"
                                wrapping="false"
                                textAlign="End"
                                textDirection="Inherit"
                                visible="true"
                            />
                        </header> 
                    </Column>
                         <Column
                        width="5.5rem"
                        hAlign="End"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>titleAddColCodigo}"
                                width="auto"
                                maxLines="1"
                                wrapping="false"
                                textAlign="End"
                                textDirection="Inherit"
                                visible="true"
                            />
                        </header>
                    </Column>
                    <Column
                        width="25rem"
                        hAlign="Left"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>txtTableDescriptions}"
                                width="auto"
                                maxLines="1"
                                wrapping="false"
                                textAlign="Left"
                                textDirection="Inherit"
                                visible="true"
                            />
                        </header>
                    </Column>
               
                    <Column
                        width="3.5rem"
                        hAlign="Left"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>txtTableUMV}"
                                width="100%"
                                maxLines="1"
                                wrapping="true"
                                textAlign="End"
                                textDirection="Inherit"
                                visible="true"
                            />
                        </header>
                    </Column>
                    <Column
                        width="7rem"
                        hAlign="End"
                        vAlign="Middle"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        popinDisplay="Inline"
                        mergeDuplicates="false"
                    >
                        <header>
                            <Text
                                text="{i18n>txtStock}"
                                width="auto"
                                maxLines="1"
                                wrapping="false"
                                textAlign="End"
                                textDirection="Inherit"
                                visible="{= !${oModelUser>/bIsCliente}}"
                            />
                        </header>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Inactive">
                        <cells>
                            <Input
                                value="{oModelProyect>cantidad}"
                                width="auto"
                                liveChange="_onLiveChangeCantidad"     
                                valueState="{oModelProyect>state}"
                                valueStateText="Cantidad incorrecta"
                                editable="{= Number(${oModelProyect>Clabs}) > 0 }"
                            />
                            <ObjectStatus
                                text="{oModelProyect>Matnr}"
                               />
                            <ObjectStatus
                                text="{oModelProyect>Maktx}"
                                />
                            <HBox>
                                <ObjectStatus
                                    text="{oModelProyect>Meins}"
                                    
                                />
                            
                            </HBox>
                            <ObjectStatus
                                text="{path: 'oModelProyect>Clabs', formatter: '.formatter.currencyFormat'}"
                               
                                visible="{= !${oModelUser>/bIsCliente}}"
                                />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
             </VBox>
        </content>
        <buttons>
            <Button
                id="btnAcceptAddManualProduct"
                text="{i18n>confirmProductText}"
                press="_onAcceptProductManual"
                custom:custom="default"
                type="Critical"
                icon="sap-icon://accept"
            />
            <Button
                id="btnCloseAddManualProduct"
                text="{i18n>cancelText}"
                press="_onPressClose"
                custom:custom="default"
                type="Reject"
                icon="sap-icon://cancel"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
