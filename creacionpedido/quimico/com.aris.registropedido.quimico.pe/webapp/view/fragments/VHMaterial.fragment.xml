<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <SelectDialog
    id="sdVHMaterial"
    title="Material"
    multiSelect="true"
    rememberSelections="false"
    liveChange=".onVHMaterialSearch"
    confirm=".onVHMaterialConfirm"
    cancel=".onVHClose"
    items="{ path: 'oModelData>/oFilterMaterial' }">
    <StandardListItem
      title="{= ${oModelData>Material} + ' - ' + ${oModelData>Description} }"
      description="{oModelData>Material}"
      type="Active"/>
  </SelectDialog>
</core:FragmentDefinition>