<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <SelectDialog
    id="sdVHDescription"
    title="Descripción"
    multiSelect="true"
    rememberSelections="false"
    liveChange=".onVHDescriptionSearch"
    confirm=".onVHDescriptionConfirm"
    cancel=".onVHClose"
    items="{ path: 'oModelData>/oFilterMaterial' }">
    <StandardListItem
      title="{oModelData>Description}"
      description="{oModelData>Material}"
      type="Active"/>
  </SelectDialog>
</core:FragmentDefinition>