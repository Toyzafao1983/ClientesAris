<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog
        id="dlgPosicionesDocumento"
        title="Referencia"
        contentWidth="55rem"
        resizable="true"
        draggable="true"
        stretchOnPhone="true">
        <VBox class="sapUiMediumMargin">

        <Panel headerText="Referencia" >
            <HBox width="100%" renderType="Bare" justifyContent="Center"  >
                <VBox class="sapUiSmallMarginEnd" width="50%">
                    <f:SimpleForm
                        id="SimpleFormRefLeft"
                        editable="false"
                        layout="ResponsiveGridLayout"
                        class="sapUiSizeCompact myCompactForm"
                        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                        emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0"
                        columnsXL="1" columnsL="1" columnsM="1">

                        <f:content>
                            <core:Title text=""/>
                            <Label text="Cliente"/>
                            <Text text="{path: 'oModelProyect>/oDatClient/CustomerFullName', formatter: '.formatter.cleanCustomerFullName'}" wrapping="false"/>
                            <Label text="Doc. Comercial"/>
                            <Text text="{oModelProyect>/inputForm/docRefSeleccionado/DocComercial}" wrapping="false"/>
                            <Label text="CL. Docum."/>
                            <Text text="{oModelProyect>/inputForm/docRefSeleccionado/ClDocum}" wrapping="false"/>
                        </f:content>
                    </f:SimpleForm>
                </VBox>
                <VBox width="35%">
                    <f:SimpleForm
                        id="SimpleFormRefRight"
                        editable="false"
                        layout="ResponsiveGridLayout"
                        class="sapUiSizeCompact myCompactForm"
                        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                        emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0"
                        columnsXL="1" columnsL="1" columnsM="1">
                        <f:content>
                            <core:Title text=""/>
                            <Label text="Inicio" />
                            <Text
                                text="{oModelProyect>/inputForm/docRefSeleccionado/FechaInicio}"
                                wrapping="false" />
                            <Label text="Fin"/>
                            <Text
                                text="{oModelProyect>/inputForm/docRefSeleccionado/FechaFin}"
                                wrapping="false"/>
                        </f:content>
                    </f:SimpleForm>
                </VBox>
            </HBox>
        </Panel>
        <ScrollContainer width="100%" height="100%" horizontal="true" vertical="true">
            <Table
                id="tblPosDocRef"
                width="100%"
                items="{path: 'oModelProyect>/aPosDocRef'}"
                mode="MultiSelect"
                selectionChange=".onPosRefSelectionChange">
               <columns>
                    <Column><Text text="Pos." width="4rem"/></Column>
                    <Column><Text text="Material" width="8rem"/></Column>
                    <Column><Text text="Descripción" width="15rem"/></Column>
                    <Column><Text text="Ctd. Original" width="8rem"/></Column>
                    <Column><Text text="Cant. Pendiente" width="12rem"/></Column>
                    <Column><Text text="Ctd. Pedido" width="14rem"/></Column>
                    <Column><Text text="UM" width="5rem"/></Column>
                   
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{oModelProyect>Pos}" />
                            <Text text="{oModelProyect>Material}"/>
                            <Text text="{oModelProyect>Descripcion}"/>
                            <Text text="{path:'oModelProyect>CtdOriginal',formatter:'.formatter.formatMonto2Dec'}"/>
                            <Text text="{path:'oModelProyect>CtdPendiente',formatter:'.formatter.formatMonto2Dec'}"/>

                            <StepInput
                                value="{path:'oModelProyect>CtdPedido', type:'sap.ui.model.type.Float'}"
                                min="0"
                                step="1"
                                largerStep="1"
                                displayValuePrecision="2"
                                width="6.8rem"
                                textAlign="End"
                                change=".onStepPedidoChange"/>

                            <Text text="{oModelProyect>UM}"/>

                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </ScrollContainer>
            <HBox justifyContent="Center" class="sapUiMediumMarginTop">
                <Button
                    text="Atrás"
                    type="Transparent"
                    class="sapUiTinyMarginEnd"
                    press=".onDocPosicionesBack"/>
                <Button
                    text="Confirmar"
                    type="Emphasized"
                    class="sapUiTinyMarginEnd"
                    press=".onDocPosicionesConfirmar"/>
                <Button
                    text="Cancelar"
                    press=".onDocPosicionesCancelar"/>
            </HBox>
        </VBox>
    </Dialog>
</core:FragmentDefinition>