<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:fd="sap.f"
  xmlns:f="sap.ui.layout.form"
  xmlns:l="sap.ui.layout"
  xmlns:core="sap.ui.core"
  xmlns:uxap="sap.uxap"
  xmlns:u="sap.ui.unified"
  controllerName="com.aris.registropedido.ceramicos.pe.controller.FormClient"
  height="100%">
<Shell >
  <fd:DynamicPage 
    headerExpanded="true"
    showFooter="true"
    fitContent="false">
    <fd:title>
      <fd:DynamicPageTitle>
        <fd:heading>
        <Title 
          text="{= 'Creación de Pedido - ' + ${oModelUser>/bUserName}}"
          level="H1" 
          textAlign="Center"/>
        </fd:heading>
          <fd:actions>
              <Button text="{i18n>textHome}" press="_onPressNavButtonForm" type="Transparent" icon="sap-icon://home" tooltip="{i18n>tooltipbtnHome}" visible="{= !${oModelUser>/hideAdvancedFields}}"/>
          </fd:actions>
      </fd:DynamicPageTitle>
    </fd:title>
      <fd:header>
          <fd:DynamicPageHeader>
           <HBox width="100%" justifyContent="SpaceBetween" alignItems="Start" wrap="NoWrap">
            <VBox width="68%" class="sapUiTinyMarginTop">
                <layoutData>
                    <FlexItemData growFactor="2" />
                </layoutData>

                <f:SimpleForm 
                    id="SimpleFormDatosCliente"
                    editable="false"
                    layout="ResponsiveGridLayout"
                    title="{i18n>textDatsClient}"
                    class="sapUiSizeCompact myCompactForm"
                    labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="3"
                    columnsXL="1" columnsL="1" columnsM="1">

                    <f:content>
                        <core:Title text=""/>

                        <Label text="{i18n>textCodClient}"/>
                        <Text text="{oModelProyect>/oDatClient/Customer}"/>

                        <Label text="{i18n>txtClient}"/>
                        <Text text="{path: 'oModelProyect>/oDatClient/CustomerFullName', formatter: '.formatter.cleanCustomerFullName'}"/>

                        <Label text="{i18n>txtRucDNI}"/>
                        <Text text="{path: 'oModelProyect>/oDatClient', formatter: '.formatter.getDocumento'}"/>

                        <Label text="{i18n>textAddress}"/>
                        <Text text="{oModelProyect>/oDireccionCliente/FullAddress}"/>

                        <Label text="{i18n>txtPuchaserOrder}"/>
                        <Input value="{oModelProyect>/inputForm/purchaseOrder}" width="100%"/>

                        <ProgressIndicator
                            id="piUpload"
                            percentValue="0"
                            displayValue="0%"
                            visible="false"
                            width="100%"
                        />

                        <Label text="{i18n>txtAdjuntOC}"/>
                        <HBox>
                            <u:FileUploader
                                id="fileUploader"
                                multiple="true"
                                buttonText="Subir"
                                name="myFileUpload"
                                buttonOnly="true"
                                uploadUrl="upload/"
                                icon="sap-icon://upload"
                                change=".handleFileChange"
                                uploadComplete=".handleUploadComplete" />

                            <MultiInput
                                id="fileTokenInput"
                                width="200px"
                                placeholder="Archivos seleccionados..."
                                showValueHelp="false"
                                tokenUpdate=".handleTokenUpdate">
                                <layoutData>
                                    <FlexItemData styleClass="sapUiTinyMarginBegin" />
                                </layoutData>
                            </MultiInput>

                            <Button
                                text="Enviar"
                                press=".onUploadAllFiles"
                                type="Emphasized"
                                class="sapUiSmallMarginBegin"
                            />
                        </HBox>
                    </f:content>
                </f:SimpleForm>
            </VBox>

            <VBox width="30%">
                <layoutData>
                    <FlexItemData growFactor="1" />
                </layoutData>

                <f:SimpleForm 
                    id="SimpleFormCreditoCliente"
                    editable="false"
                    layout="ResponsiveGridLayout"
                    class="sapUiSizeCompact myCompactForm"
                    labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="4"
                    columnsXL="1" columnsL="1" columnsM="1">
                    <f:content>
                        <core:Title text=""/>
                        <!-- Crédito Asignado -->
                        <Label text="{i18n>txtCredAsing}"/>
                        <Text
                            text="{
                                parts: [
                                    { path: 'oModelProyect>/oCreditoCliente/Assignedcredit' },
                                    { path: 'oModelProyect>/oCreditoCliente/WaersCustomer' },
                                    { path: 'oModelProyect>/oCreditoCliente/FlagClc' }
                                ],
                                formatter: '.formatter.formatAssignedCreditByFlag'
                            }"
                            textAlign="End"
                            width="60%">
                            <layoutData>
                                <l:GridData span="L3 M3 S6" />
                            </layoutData>
                        </Text>

                        <!-- Crédito Disponible -->
                        <Label text="{i18n>txtCredAvailable}"/>
                        <Text
                            text="{
                                parts: [
                                    { path: 'oModelProyect>/oCreditoCliente/Availablecredit' },
                                    { path: 'oModelProyect>/oCreditoCliente/WaersCustomer' }
                                ],
                                formatter: '.formatter.formatCreditWithCurrency'
                            }"
                            textAlign="End"
                            width="60%">
                            <layoutData>
                                <l:GridData span="L3 M3 S6" />
                            </layoutData>
                        </Text>
                        <Label text="{i18n>txtSegment}" visible="{= !${oModelUser>/bIsCliente}}"/>
                        <Text
                            text="{oModelProyect>/oClientData/DescriptionCustomerGroupPrice}" 
                            visible="{= !${oModelUser>/bIsCliente}}"
                            textAlign="End"
                            width="60%">
                            <layoutData>
                                <l:GridData span="L3 M3 S6" />
                            </layoutData>
                        </Text>

                        <Label text="{i18n>txtFechExpiration}"/>
                        <DatePicker id="OCFechExpiration"
                            value="{oModelProyect>/inputForm/ocExpDate}"
                            textAlign="Center"
                            valueFormat="dd/MM/yyyy"
                            displayFormat="dd/MM/yyyy"/>
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </HBox>
      </fd:DynamicPageHeader>
    </fd:header>
 <fd:content>
      <VBox>
        <f:SimpleForm 
          id="SimpleFormDisplay480_Trial1"
          editable="false"
          layout="ResponsiveGridLayout"
          title="{i18n>txtCondComers}"
          class="sapUiSizeCompact"
          emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0"
          labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
          columnsXL="2" columnsL="2" columnsM="2">
          <f:content>
            <core:Title text=""/>
           <Label text="{i18n>txtTipDocument}" required="true"/>
             <HBox fitContainer="true">
               <Select
                  selectedKey="{oModelProyect>/inputForm/tipDocument}"
                  change=".onTipDocumentChange"
                  items="{ path: 'oModelData>/oTipDocumentData' }"
                  forceSelection="false"
                  enabled="{oModelProyect>/inputForm/isTipDocumentEnabled}">
                  <core:Item key="" text="-- Seleccione --" />
                  <core:Item key="{oModelData>auart}"
                            text="{= ${oModelData>auart} + ' - ' + ${oModelData>bezei} }" />
                  <layoutData>
                      <FlexItemData growFactor="1" />
                  </layoutData>
              </Select>
                <Button
                    id="btnPedidoConReferencia"
                    text="Referencia"
                    icon="sap-icon://chain-link"
                    type="Transparent"
                    class="sapUiTinyMarginBegin"
                    width="auto"
                    visible="{oModelProyect>/bShowBtnPedidoRef}"
                    press=".onOpenPedidoConReferencia"/>
            </HBox>
            <Label text="{i18n>textMoney}" required="true" />
            <Input 
                value="{oModelProyect>/inputForm/moneda}"
                editable="false"
                textAlign="Left" />
             <Label text="{i18n>txtConditionsPay}" required="true"/>
              <ComboBox
                  items="{
                      path: 'oModelData>/oConditionPay'
                  }"
                  selectedKey="{oModelProyect>/inputForm/cbCondPago}"
                  placeholder="Seleccione condición de pago"
                  enabled="{oModelProyect>/isFormEnabled}"
                  selectionChange=".onSelectCondPago">
                  <core:Item key="{oModelData>Conditionn}" text="{oModelData>DesCondition}" />
              </ComboBox>

            <Label text="{i18n>txtConditionsDelivery}" required="true"/>
            <VBox>
              <RadioButton text="{i18n>txtClientCollet}" groupName="condEntregaForm"
                  selected="{= ${oModelProyect>/inputForm/tipoEntrega} === '1' }"
                  select=".onSelectRadioComprobante"
                  enabled="{oModelProyect>/isFormEnabled}"/>

              <RadioButton text="{i18n>txtDirectDispatch}" groupName="condEntregaForm"
                  selected="{= ${oModelProyect>/inputForm/tipoEntrega} === '2' }"
                  select=".onSelectRadioComprobante"
                  enabled="{oModelProyect>/isFormEnabled}"/>

              <RadioButton text="{i18n>txtDispatchAgency}" groupName="condEntregaForm"
                  selected="{= ${oModelProyect>/inputForm/tipoEntrega} === '3' }"
                  select=".onSelectRadioComprobante"
                  enabled="{oModelProyect>/isFormEnabled}"/>
            </VBox>
             <Label text="{i18n>txtDirectionsAgency}" visible="{= ${oModelProyect>/inputForm/tipoEntrega} === '3' }"/>
              <ComboBox
                  visible="{= ${oModelProyect>/inputForm/tipoEntrega} === '3' }"
                  selectedKey="{oModelProyect>/inputForm/direccionAgencia}"
                  items="{
                      path: 'oModelProyect>/oAgenciasCliente'
                  }"
                  showSecondaryValues="true"
                  filterSecondaryValues="true"
                  showClearIcon="true"
                  placeholder="Seleccione una agencia"
                  change="onAgenciaChange">
                  
                  <core:ListItem
                      key="{oModelProyect>Customer}"
                      text="{oModelProyect>Agencyaddress}"
                      additionalText="{oModelProyect>Agencyname}" />
              </ComboBox>
            <core:Title text=""/>
              <Label
                text="{i18n>txtSellerPrincipal}"
                visible="{ path: 'oModelUser>/bIsCliente', formatter: '.formatter._visibleNoCliente' }"
              />

              <Text
                visible="{ path: 'oModelUser>/bIsCliente', formatter: '.formatter._visibleNoCliente' }"
                text="{
                  parts: [
                    { path: 'oModelUser>/bIsCliente' },
                    { path: 'oModelProyect>/oClientData/kunn2' },
                    { path: 'oModelProyect>/oClientData/Seller' },
                    { path: 'oModelUser>/bBPFinal' },
                    { path: 'oModelUser>/bUserName' }
                  ],
                  formatter: '.formatter._textSellerPrincipalSmart'
                }"
              />
              <Label
                text="{i18n>txtSellerSupport}"
                visible="{
                  parts: [
                    { path: 'oModelUser>/bIsCliente' },
                    { path: 'oModelProyect>/oClientData/kunn2' },
                    { path: 'oModelUser>/bBPFinal' }
                  ],
                  formatter: '.formatter._visibleSupportSeller'
                }"
              />

              <Input
                value="{= ${oModelUser>/bBPFinal} + ' - ' + ${oModelUser>/bUserName} }"
                enabled="false"
                visible="{
                  parts: [
                    { path: 'oModelUser>/bIsCliente' },
                    { path: 'oModelProyect>/oClientData/kunn2' },
                    { path: 'oModelUser>/bBPFinal' }
                  ],
                  formatter: '.formatter._visibleSupportSeller'
                }"
              />
            <Label text="{i18n>txtTypeChange}"/>
            <Input value="{
                  path: 'oModelData>/oTipChangeData',
                  formatter: '.formatTipoCambioLabel'
                  }" 
                  editable="false"
                  width="100%"/>
            <Label text="{i18n>txtReason}" required="true" visible="{oModelProyect>/inputForm/showReasonOrd}"/>
                <Select  
                  selectedKey="{oModelProyect>/inputForm/reasonOrd}"
                  items="{
                      path: 'oModelData>/oReason'
                  }"
                  visible="{oModelProyect>/inputForm/showReasonOrd}"
                  change="onReasonOrdChange"
                  enabled="{oModelProyect>/isFormEnabled}"
                  forceSelection="false">
                  <core:Item key="" text="-- Seleccione --" /> 
                  <core:Item key="{oModelData>ReasonRequest}"   text="{= ${oModelData>ReasonRequest} + ' - ' + ${oModelData>Description} }" />
                </Select>          
          </f:content>
        </f:SimpleForm>
        <f:SimpleForm id="SimpleFormDisplay354wideDual"
          editable="true"
          layout="ResponsiveGridLayout"
          labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
          columnsXL="1" columnsL="1" columnsM="1">
          <f:content>
            <Label text="{i18n>txtDestination}"/>
              <ComboBox
                  id="DestinationTextandCeramicos"
                  selectedKey="{oModelProyect>/inputForm/destinoCeramico}"
                  items="{
                      path: 'oModelProyect>/oFinalDestinosCliente'
                  }"
                  showSecondaryValues="true"
                  filterSecondaryValues="true"
                  showClearIcon="true"
                  placeholder="Seleccione destino Ceramicos"
                  enabled="{oModelProyect>/isFormEnabled}"
                  width="100%">
                  <core:ListItem
                      key="{oModelProyect>Id}"
                      text="{oModelProyect>Text}" 
                      additionalText="{oModelProyect>Name}" />
              </ComboBox>
            <Label text="{i18n>txtObservationsPed}"/>
              <TextArea
              id="ObservationsPed"
              value="{oModelProyect>/inputForm/obsPedido}"
              valueLiveUpdate="true"
              rows="4"
              width="100%"
              enabled="{oModelProyect>/isFormEnabled}"/>
            <Label text="{i18n>txtObservationsDelivery}"/>
            <TextArea
              id="ObservationsDelivery"
              value="{oModelProyect>/inputForm/obsDelivery}"
              valueLiveUpdate="true"
              rows="4"
              width="100%"
              enabled="{oModelProyect>/isFormEnabled}"/>
            

          </f:content>
        </f:SimpleForm>
            <f:SimpleForm id="SimpleFormSeparation"
          editable="false"
          layout="ResponsiveGridLayout"
          labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
          columnsXL="3" columnsL="2" columnsM="2"
          visible="{oModelProyect>/inputForm/showSeparationDates}">
          <f:content>
     
          <HBox width="100%" justifyContent="SpaceBetween" wrap="Wrap"
                visible="{oModelProyect>/inputForm/showSeparationDates}">
              <VBox width="48%">
                  <Label text="{i18n>txtFechInit}"/>
                  <DatePicker
                      id="FechInit"
                      dateValue="{oModelProyect>/Main/filter/fechInicio}"
                      enabled="false"
                      textAlign="Center"
                      valueFormat="dd/MM/yyyy"
                      displayFormat="dd/MM/yyyy"/>
              </VBox>
              <VBox width="48%">
                  <Label text="{i18n>txtFechEnd}"/>
                  <DatePicker
                      id="FechEnd"
                      value="{oModelProyect>/inputForm/fechFin}"
                      textAlign="Center"
                      valueFormat="dd/MM/yyyy"
                      displayFormat="dd/MM/yyyy"/>
              </VBox>
          </HBox>
          </f:content>
        </f:SimpleForm>
       
      </VBox>
    </fd:content>
    <fd:footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="{i18n>txtAddMaterial}" 
                type="Emphasized" 
                width="40%" 
                press="_onPressMaterialDetail"/>
        <ToolbarSpacer />
      </OverflowToolbar>
    </fd:footer>

  </fd:DynamicPage>
  </Shell>
</mvc:View>
