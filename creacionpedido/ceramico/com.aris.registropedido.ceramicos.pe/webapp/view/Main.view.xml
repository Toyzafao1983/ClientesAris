<mvc:View controllerName="com.aris.registropedido.ceramicos.pe.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:svm="sap.ui.comp.smartvariants"
    height="100%">

    <Shell appWidthLimited="false">
        <Page id="page" showHeader="false">
            <ObjectHeader
                title="{= 'Bienvenido(a): ' + ${oModelUser>/bUserName}}"
                condensed="true"
                />
            <f:DynamicPage headerExpanded="true">
                <f:header>
                    <f:DynamicPageHeader pinnable="false">
                        <f:content>
                            <fb:FilterBar filterContainerWidth="15rem" reset="onReset" search="_onPressExecute" showFilterConfiguration="true"
                                    showRestoreButton="false" showClearOnFB="true" clear="onClearFilters" useToolbar="false">
                                    <fb:filterItems>
                                        <fb:FilterItem name="A" label="{i18n>lblVendedores}">
                                        <fb:control> 
                                            <MultiInput
                                                id="multiInputSeller"
                                                placeholder="Ingrese código o abra búsqueda"
                                                showValueHelp="true"
                                                valueHelpRequest="FilterSelling"
                                                suggest="onSuggestSeller"
                                                suggestionItemSelected="onSellerSuggestionSelected"
                                                tokenUpdate="onSellerTokenUpdate"
                                                showSuggestion="true"
                                                suggestionItems="{ path: 'oModelProyect>/oSellerUnique' }">

                                                <core:Item 
                                                    key="{oModelProyect>kunn2}" 
                                                    text="{= ${oModelProyect>kunn2} + ' - ' + ${oModelProyect>Seller} }" 
                                                />
                                            </MultiInput>
                                        </fb:control>
                                    </fb:FilterItem>
                                        
                                        <fb:FilterItem name="B" label="{i18n>lblCodCliente}">
                                        <fb:control>
                                           <MultiInput
                                                id="multiInputCodClient"
                                                enabled="{oModelProyect>/Main/ui/bEnableClientFilters}"
                                                placeholder="Ingrese código o abra búsqueda"
                                                showValueHelp="true"
                                                valueHelpRequest="FilterCodClient"
                                                showSuggestion="true"
                                                suggest="onSuggestClient"
                                                tokenUpdate="onTokenUpdateClient"
                                                suggestionItems="{ path: 'oModelProyect>/oClienteFilter' }">
                                                <core:Item key="{oModelProyect>Customer}" text="{= ${oModelProyect>Customer} + ' - ' + ${oModelProyect>CustomerFullName} }" />
                                            </MultiInput>
                                        </fb:control>
                                    </fb:FilterItem>
                                        
                                        <fb:FilterItem name="D" label="{i18n>lblRazonSocial}">
                                            <fb:control>
                                                <MultiInput
                                                    id="multiInputRazonSocial"
                                                    enabled="{oModelProyect>/Main/ui/bEnableClientFilters}"
                                                    placeholder="Seleccionar razón social"
                                                    showValueHelp="true"
                                                    valueHelpRequest="FilterRazonSocial"
                                                    showSuggestion="true"
                                                    suggest="onSuggestRazonSocial"
                                                    tokenUpdate="onTokenUpdateRazonSocial"
                                                    suggestionItems="{ path: 'oModelProyect>/oClienteFilter' }">
                                                    <core:Item key="{oModelProyect>Customer}" text="{oModelProyect>CustomerFullName}" />
                                                </MultiInput>
                                            </fb:control>
                                        </fb:FilterItem>

                                        <fb:FilterItem name="E" label="{i18n>lblDocumento}">
                                            <fb:control>
                                                <MultiInput
                                                    id="multiInputDocument"
                                                    enabled="{oModelProyect>/Main/ui/bEnableClientFilters}"
                                                    placeholder="Seleccionar RUC"
                                                    showValueHelp="true"
                                                    valueHelpRequest="FilterDocument"
                                                    showSuggestion="true"
                                                    suggest="onSuggestDocument"
                                                    tokenUpdate="onTokenUpdateDocument"
                                                    suggestionItems="{ path: 'oModelProyect>/oClienteFilter' }">
                                                    <core:Item key="{path: 'oModelProyect>', formatter: '.formatter.getFirstTaxNumber'}"
                                                            text="{path: 'oModelProyect>', formatter: '.formatter.getFirstTaxNumber'}" />
                                                </MultiInput>
                                            </fb:control>
                                        </fb:FilterItem>
                                    </fb:filterItems>
                                </fb:FilterBar>
                            </f:content>
                        </f:DynamicPageHeader>
                    </f:header>
                <f:content>
                    <core:Fragment fragmentName="com.aris.registropedido.ceramicos.pe.view.fragments.TableMain" type="XML"/>
                </f:content>
            </f:DynamicPage>
        </Page>
    </Shell>
</mvc:View>
