<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout"
	xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1" xmlns:f="sap.ui.layout.form">
    <Table items="{oModelProyect>/oReporte}"  mode="SingleSelectMaster" growingThreshold="20" id="TableClient" growingScrollToLoad="false" growing="true">
         <columns>
                        <Column width="5.5rem" hAlign="End" vAlign="Middle" minScreenWidth="Phone" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                            <header>
                                <Text text="{i18n>titleColCodeClient}" width="auto" maxLines="2" wrapping="true" textAlign="Begin" textDirection="Inherit" visible="true"/>
                            </header>
                        </Column>
                        <Column width="20rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                            <header>
                                <Text text="{i18n>titleColCompanyName}" width="auto" maxLines="1" wrapping="false" textAlign="Begin" textDirection="Inherit" visible="true"/>
                            </header>
                        </Column>
                        <Column width="8rem" hAlign="End" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                            <header>
                                <Text text="{i18n>titleColDoc}" width="auto" maxLines="2" wrapping="true" textAlign="Begin" textDirection="Inherit" visible="true"/>
                            </header>
                        </Column>
                        <Column width="10rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                            <header>
                                <Text text="{i18n>titleColGroup}" width="auto" maxLines="1" wrapping="false" textAlign="Begin" textDirection="Inherit" visible="true"/>
                            </header>
                        </Column>
                        <Column width="9rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                            <header>
                                <Text text="{i18n>titleColCredAsig}" width="auto" maxLines="1" wrapping="false" textAlign="Begin" textDirection="Inherit" visible="true"/>
                            </header>
                        </Column>
                        <Column width="10rem" hAlign="Left" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                            <header>
                                <Text text="{i18n>textbtnBVen}" width="auto" maxLines="1" wrapping="false" textAlign="Begin" textDirection="Inherit" visible="true"/>
                            </header>
                        </Column>
                    </columns>
                    <items>
                    <ColumnListItem type="Inactive">
                                        <cells>
                                            <Link text="{oModelProyect>Customer}" press="_onPressNavigateForm"/>
                                            <Text text="{oModelProyect>CustomerFullName}"/>
                                            <Text text="{path: 'oModelProyect>', formatter: '.formatter.getDocumento'}"/>
                                            <Text text="{oModelProyect>DescriptionCustomerGroup}"/>
                                            <Text text="{oModelProyect>DescriptionConditionPayment}"/>
                                            <Text text="{oModelProyect>Seller}"/>
                                        </cells>
                        </ColumnListItem>
                    </items>
         </Table>
</core:FragmentDefinition>