    <core:FragmentDefinition 
    xmlns:core="sap.ui.core" 
    xmlns="sap.m" 
    xmlns:fb="sap.ui.comp.filterbar" 
    xmlns:l="sap.ui.layout"
    xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
        <SelectDialog
            id="ValueHelpFormat"
            title="Formato"
            multiSelect="true"
            search=".onFormatLiveChange"
            liveChange=".onFormatLiveChange"
            confirm=".onDialogFormatConfirm"
            cancel=".onDialogFormatCancel"
            items="{ path: 'oModelData>/oFiltroFormat' }">
            <StandardListItem
                title="{oModelData>Display}"
                type="Active" />
        </SelectDialog>
    </core:FragmentDefinition>