<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form">
    <Table  items="{oModelProyect>/oStockTextilStockPen}"  mode="None" growingThreshold="20" width="auto">
        <columns>
            <Column width="18%" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>titleDetTexsPenOrder}" width="auto" />
                </header>
            </Column>
            <Column width="32%" hAlign="Begin" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <HBox justifyContent="Center" width="100%">
                        <Text text="{i18n>titleDetTexsPenCustomer}" width="auto" />
                    </HBox>
                </header>
            </Column>
            <Column width="13%" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>titleDetTexsPenOrderDate}" width="auto" />
                </header>
            </Column>

            <Column width="13%" hAlign="End" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false" visible="{= !${oModelUser>/rCliente}}">
                <header>
                    <HBox justifyContent="Center" width="100%">
                        <Text text="{i18n>titleDetTexsPenRequestedQuantity}" width="auto" />
                    </HBox>
                </header>
            </Column>
            <Column width="8%" hAlign="End" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false" visible="{= !${oModelUser>/rCliente}}">
                <header>
                    <HBox justifyContent="Center" width="100%">
                        <Text text="{i18n>titleDetTexsPenPendingQuantity}" width="auto" />
                    </HBox>
                </header>
            </Column>
            <Column width="16%" hAlign="Begin" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false" visible="{= !${oModelUser>/rCliente}}">
                <header>
                    <HBox justifyContent="Center" width="100%">
                        <Text text="{i18n>titleDetTexsPenStatus}" width="auto" />
                    </HBox>
                </header>
            </Column>
            
        </columns>
       <items>
            <ColumnListItem type="Inactive"  >
                <cells>
                    <Text text="{path:'oModelProyect>Pedido'}"/>
                    <Text text="{path:'oModelProyect>Cliente'}"/>
                    <Text text="{path:'oModelProyect>FechaPedido'}"/>
                    <Text text="{path:'oModelProyect>CantSoli'}"/>
                    <Text text="{path:'oModelProyect>CantPendi'}"/>
                    <Text text="{path:'oModelProyect>Estado'}"/>
                </cells>
            </ColumnListItem>
        </items>
     
    </Table>
</core:FragmentDefinition>